# ==========================================
# LNHC Backend Environment Variables Template
# ==========================================
# Copy this file, rename it to '.env', and fill in your actual credentials.

# Your PostgreSQL Database Connection String
DATABASE_URL=postgresql://user:password@host:port/dbname?sslmode=require

# Master Admin Credentials (Used to create the initial admin account on first boot)
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=your_secure_password_here
